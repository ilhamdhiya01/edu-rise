FROM node:20-alpine
# Add libc6-compat because Alpine environment needs it for some native libraries
RUN apk add --no-cache libc6-compat
WORKDIR /app

RUN npm install -g pnpm

# Copy package files to install dependencies in the container
COPY package.json pnpm-lock.yaml ./

# Install all dependencies including devDependencies like Vite/Vitest, etc.
RUN pnpm install

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# Run server development using pnpm
CMD ["pnpm", "dev"]